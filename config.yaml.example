# smt — Schema Migration Tool configuration
#
# SMT extracts the source schema and writes matching target-dialect DDL.
# Unlike DMT, it does not transfer rows. Applying DDL to a target database
# is explicit via `smt create --apply` or `smt sync --apply`.

source:
  type: mssql                           # mssql | postgres | mysql
  host: localhost
  port: 1433
  database: StackOverflow2010
  user: sa
  password: ${MSSQL_PASSWORD}           # ${env:VAR}, ${file:/path}, or literal
  schema: dbo

target:
  type: postgres                        # mssql | postgres | mysql
  schema: public
  # Connection fields are only required when using --apply or health-checking
  # the target. Leave them out for DDL-only generation.
  # host: localhost
  # port: 5432
  # database: stackoverflow
  # user: postgres
  # password: ${PG_PASSWORD}

schema_generation:
  mode: deterministic                  # deterministic
  unknown_type_policy: fail            # fail | warn | text_fallback

ai_review:
  enabled: false                       # optional review of deterministic DDL
  mode: warn                           # warn | fail
  # model: strong-reviewer             # provider entry in ~/.secrets/smt-config.yaml
  diagnose_failures: false             # advise the user on extract/render failures
                                       # (cause + suggestions only — never edits or
                                       #  retries DDL); uses the model above
  # Note: with review enabled the un-configured render fan-out drops from 8
  # to 2 so cold-cache runs stay under provider rate limits (#54). Set
  # migration.ai_concurrency explicitly to override.

profile:
  name: example
  description: |
    Example profile, stored encrypted in SQLite.
    Edit this description for your environment.

# Optional migration overrides. Omit this block for the default full-schema
# plan: tables, indexes, foreign keys, and check constraints.
# migration:
#   include_tables: []                  # if set, only matching tables are scoped
#   exclude_tables:
#     - __*
#     - temp_*
#   create_indexes: true
#   create_foreign_keys: true
#   create_check_constraints: true
#   data_dir: ~/.smt

# Slack notifications (optional). AI provider keys live in the secrets file
# at ~/.secrets/smt-config.yaml — never put them here.
slack:
  enabled: false
  webhook_url: ${SLACK_WEBHOOK_URL}
  channel: "#data-engineering"
  username: smt
